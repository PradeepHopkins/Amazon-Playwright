{
  "author": "",
  "description": "End-to-end test automation suite using Playwright for Amazon",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0",
    "allure-playwright": "^3.6.0"
  },
  "keywords": [
    "playwright",
    "e2e"
  ],
  "license": "ISC",
  "main": "index.js",
  "name": "amazon-playwright",
  "scripts": {
    "test": "playwright test",
    "test:allure-report": "allure generate allure-results -c -o allure-report && allure open allure-report",
    "test:chromium": "playwright test --project=chromium",
    "test:debug": "playwright test --debug",
    "test:firefox": "playwright test --project=firefox",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:ui": "playwright test --ui",
    "test:watch": "playwright test --watch",
    "test:webkit": "playwright test --project=webkit"
  },
  "type": "commonjs",
  "version": "1.0.0"
}
